# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/menusanjuan"

# Google Maps (used in customer checkout for delivery location)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your_google_maps_api_key"

# Cloudflare R2 (restaurant image uploads)
R2_ACCOUNT_ID="your_account_id"
R2_ACCESS_KEY="your_access_key"
R2_SECRET_KEY="your_secret_key"
R2_BUCKET="menusanjuan-images"

# MailerSend (transactional emails — verification, password reset)
MAILERSEND_API_KEY="your_mailersend_api_key"
